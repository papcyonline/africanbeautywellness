# Copy this file to .env.local and fill in the values. Never commit real keys.

# Public site URL (used for metadata, social card, payment redirect)
NEXT_PUBLIC_SITE_URL=http://localhost:3100

# Pexels — only used by scripts/fetch-images.mjs at build time
PEXELS_API_KEY=

# Supabase — Dashboard → Project Settings → API
# URL + service-role key are server-only (used to read/insert/update + uploads).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Flutterwave — Dashboard → Settings → API Keys
FLW_SECRET_KEY=
NEXT_PUBLIC_FLW_PUBLIC_KEY=

# Admin portal login. REQUIRED in production, or /admin is left unprotected.
# ADMIN_SESSION_SECRET: a long random string (e.g. `openssl rand -hex 32`).
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=
